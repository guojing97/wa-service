{
  "name": "wa-service",
  "version": "1.0.0",
  "description": "WhatsApp API Service using Express.js and Baileys",
  "main": "src/app.js",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "prod": "pm2 start ecosystem.config.js --env production",
    "prod:stop": "pm2 stop wa-service",
    "prod:restart": "pm2 restart wa-service",
    "prod:logs": "pm2 logs wa-service"
  },
  "keywords": ["whatsapp", "api", "baileys", "express"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "^6.7.16",
    "axios": "^1.7.9",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "pino": "^9.6.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
}
